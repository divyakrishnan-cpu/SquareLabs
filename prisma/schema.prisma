generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")           // Neon pooled connection (provided by Vercel integration)
  directUrl = env("DATABASE_URL_UNPOOLED")  // Neon direct connection (provided by Vercel integration)
}

// ── Auth ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role           UserRole     @default(TEAM_MEMBER)
  department     String?                          // e.g. "Social", "Design", "Marketing"
  accessSections AppSection[] @default([DASHBOARD])
  teamId         String?
  team           Team?        @relation(fields: [teamId], references: [id])
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  accounts         Account[]
  sessions         Session[]
  tasks            Task[]    @relation("AssignedTasks")
  calendarItems    ContentCalendarItem[]
  scripts          ContentScript[]
  series           ContentSeries[]
  metaIntegrations     MetaIntegration[]
  youtubeIntegrations  YoutubeIntegration[]
  linkedinIntegrations LinkedinIntegration[]
  designRequestsMade   DesignRequest[]       @relation("RequestedByUser")
  designRequestsOwned  DesignRequest[]       @relation("AssignedDesigner")
  designDailyLogs      DesignDailyLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Teams ──────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  HEAD_OF_MARKETING
  TEAM_LEAD
  TEAM_MEMBER
  HR_VIEWER
}

// Sections a user is allowed to access (stored as array on User)
enum AppSection {
  DASHBOARD
  SOCIAL
  DESIGN_OPS
  GMB
  PORTALS
  SETTINGS
  TEAM_HUB
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  members     User[]
  tasks       Task[]

  @@map("teams")
}

// ── Tasks ──────────────────────────────────────────────────────────────────

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  APPROVED
  DONE
  CANCELLED
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?
  teamId      String
  assigneeId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  team        Team         @relation(fields: [teamId], references: [id])
  assignee    User?        @relation("AssignedTasks", fields: [assigneeId], references: [id])

  @@map("tasks")
}

// ── Social Media — Verticals & Platforms ──────────────────────────────────

enum Vertical {
  SY_INDIA
  SY_UAE
  INTERIOR
  SQUARE_CONNECT
  UM
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  YOUTUBE
  TWITTER
  PINTEREST
}

// ── SM-01: Social Metrics (daily snapshot per vertical + platform) ─────────

model SocialMetricSnapshot {
  id               String         @id @default(cuid())
  vertical         Vertical
  platform         SocialPlatform
  date             DateTime       @db.Date
  followers        Int            @default(0)
  follows          Int            @default(0)  // gained that day
  unfollows        Int            @default(0)  // lost that day
  netFollowers     Int            @default(0)
  views            Int            @default(0)
  reach            Int            @default(0)
  impressions      Int            @default(0)
  interactions     Int            @default(0)  // total interactions (sum)
  likes            Int            @default(0)  // per-day likes
  comments         Int            @default(0)  // per-day comments
  saves            Int            @default(0)  // per-day saves
  shares           Int            @default(0)  // per-day shares
  linkClicks       Int            @default(0)
  profileVisits    Int            @default(0)
  totalContacts    Int            @default(0)
  postsPublished   Int            @default(0)
  videosPublished  Int            @default(0)
  staticsPublished Int            @default(0)
  createdAt        DateTime       @default(now())

  @@unique([vertical, platform, date])
  @@map("social_metric_snapshots")
}

// ── SM-01b: Monthly Social Report (manually logged aggregate per vertical) ─

model SocialMonthlyReport {
  id               String    @id @default(cuid())
  vertical         Vertical
  year             Int                           // e.g. 2026
  month            Int                           // 1–12

  // Audience
  totalFollowers   Int       @default(0)         // cumulative followers at month-end
  newFollowers     Int       @default(0)         // gained this month
  unfollows        Int       @default(0)         // lost this month
  netFollowers     Int       @default(0)         // = newFollowers - unfollows

  // Reach & visibility
  totalViews       Int       @default(0)
  totalReach       Int       @default(0)
  totalImpressions Int       @default(0)

  // Engagement
  interactions     Int       @default(0)         // likes + comments + shares + saves
  linkClicks       Int       @default(0)
  profileVisits    Int       @default(0)
  totalContacts    Int       @default(0)

  // Publishing
  postsPublished   Int       @default(0)
  videosPublished  Int       @default(0)
  staticsPublished Int       @default(0)

  // Per-platform JSON breakdown (optional)
  // [{ platform: "INSTAGRAM", followers, reach, interactions, posts, videos, statics }]
  platformBreakdown Json?

  notes            String?   @db.Text
  enteredById      String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([vertical, year, month])
  @@map("social_monthly_reports")
}

// ── SM-02: Competitor Configuration ───────────────────────────────────────

model Competitor {
  id        String         @id @default(cuid())
  vertical  Vertical
  name      String
  platform  SocialPlatform
  handle    String
  profileUrl String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())

  snapshots CompetitorSnapshot[]

  @@map("competitors")
}

model CompetitorSnapshot {
  id           String     @id @default(cuid())
  competitorId String
  date         DateTime   @db.Date
  followers    Int        @default(0)
  postsCount   Int        @default(0)
  avgEngRate   Float      @default(0)
  topThemes    Json?      // string[]
  createdAt    DateTime   @default(now())

  competitor   Competitor @relation(fields: [competitorId], references: [id])

  @@unique([competitorId, date])
  @@map("competitor_snapshots")
}

// ── SM-02: Content Calendar (AI planned) ──────────────────────────────────

enum CalendarItemStatus {
  PLANNED
  SCRIPT_IN_PROGRESS
  SCRIPT_READY
  VIDEO_UPLOADED
  SCHEDULED
  PUBLISHED
  DELAYED
  RESCHEDULED
  CANCELLED
}

enum ContentType {
  REEL
  CAROUSEL
  STATIC
  STORY
  YOUTUBE_VIDEO
  SHORT
}

enum ContentCategory {
  LISTING
  EDUCATION
  BRAND
  TESTIMONIAL
  FESTIVE
  MARKET_UPDATE
  TIPS
  BEHIND_SCENES
}

enum DelayReason {
  SHOOT_PENDING
  SHOOT_DELAYED
  EDIT_DELAYED
  APPROVAL_PENDING
  CREATIVE_NOT_READY
  TALENT_UNAVAILABLE
  TECHNICAL_ISSUE
  STRATEGY_CHANGE
  OTHER
}

// ── Content Series ─────────────────────────────────────────────────────────
// e.g. "She Leads", "Ghar Wapsi", "Market Mondays"

model ContentSeries {
  id               String    @id @default(cuid())
  name             String                        // "She Leads"
  description      String?   @db.Text
  vertical         Vertical
  color            String    @default("#2563eb") // hex color for UI
  emoji            String?                       // optional emoji icon
  targetPerMonth   Int?                          // e.g. 4 videos/month
  targetPerWeek    Int?                          // e.g. 1 video/week
  platforms        SocialPlatform[]              // which platforms this series runs on
  isActive         Boolean   @default(true)
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  createdBy        User?               @relation(fields: [createdById], references: [id])
  calendarItems    ContentCalendarItem[]

  @@map("content_series")
}

model ContentCalendarItem {
  id               String             @id @default(cuid())
  vertical         Vertical
  platforms        SocialPlatform[]
  contentType      ContentType
  category         ContentCategory
  title            String
  hook             String?            @db.Text
  topic            String?            @db.Text
  seriesId         String?                       // link to ContentSeries
  assignedToId     String?
  plannedDate      DateTime
  scheduledAt      DateTime?
  publishedAt      DateTime?
  status           CalendarItemStatus @default(PLANNED)
  delayReason      DelayReason?
  delayNote        String?
  rescheduledFrom  DateTime?
  videoUrl         String?
  caption          String?            @db.Text
  instagramLink    String?
  youtubeLink      String?
  linkedinLink     String?
  facebookLink     String?
  aiConfidence     Float?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  series           ContentSeries?     @relation(fields: [seriesId], references: [id])
  assignedTo       User?              @relation(fields: [assignedToId], references: [id])
  script           ContentScript?
  notifications    PublishNotification[]

  @@map("content_calendar_items")
}

// ── SM-03: Content Scripts ─────────────────────────────────────────────────

enum ScriptStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
}

model ContentScript {
  id             String       @id @default(cuid())
  calendarItemId String       @unique
  version        Int          @default(1)
  status         ScriptStatus @default(DRAFT)
  hook           String?      @db.Text
  body           String?      @db.Text
  cta            String?      @db.Text
  captionInsta   String?      @db.Text
  captionLinkedin String?     @db.Text
  captionYoutube  String?     @db.Text
  estimatedDuration Int?      // seconds
  aiGenerated    Boolean      @default(false)
  authorId       String?
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  calendarItem   ContentCalendarItem @relation(fields: [calendarItemId], references: [id])
  author         User?               @relation(fields: [authorId], references: [id])

  @@map("content_scripts")
}

// ── Meta (Instagram & Facebook) OAuth Integrations ────────────────────────
// One row per connected Facebook Page (which carries an optional linked
// Instagram Business Account). Tokens are stored per-page so a user can
// connect multiple pages / verticals independently.

model MetaIntegration {
  id                  String    @id @default(cuid())
  userId              String
  vertical            Vertical?                      // null = "all verticals"
  // Facebook Page
  pageId              String
  pageName            String?
  pageAccessToken     String    @db.Text             // long-lived page token (60 days)
  userAccessToken     String?   @db.Text             // long-lived USER token — needed for instagram_manage_insights
  tokenExpiresAt      DateTime?
  // Linked Instagram Business Account (may be null if page has no IG account)
  instagramAccountId  String?
  instagramHandle     String?
  instagramName       String?
  profilePictureUrl   String?
  followersCount      Int?
  followsCount        Int?
  mediaCount          Int?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id])

  @@unique([userId, pageId])
  @@map("meta_integrations")
}

// ── ORM-01: GMB Location Registry ─────────────────────────────────────────

model GmbLocation {
  id           String   @id @default(cuid())
  business     String   // Square Yards, Interior Company, Urban Money, etc.
  city         String
  country      String
  name         String   // Full display name of the GMB listing
  address      String   @db.Text
  gmbUrl       String   // business.google.com management URL
  mapsUrl      String?  // Short Google Maps URL (maps.app.goo.gl/...) for reports
  displayLabel String?  // Custom label shown in reports, e.g. "Mumbai (Andheri East)"
  handledBy    String?  // Internal, Agency, or null
  status       String   @default("active") // active | permanently_closed
  placeId      String?  // Google Maps Place ID (for Places API lookups)
  notes        String?

  snapshots    GmbRatingSnapshot[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("gmb_locations")
}

// ── ORM-02: GMB Weekly Rating Snapshots ───────────────────────────────────

model GmbRatingSnapshot {
  id           String      @id @default(cuid())
  locationId   String
  location     GmbLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  weekStart    DateTime    // ISO Monday of the snapshot week (YYYY-MM-DD 00:00 UTC)
  rating       Float?      // Star rating (e.g. 4.2)
  reviewCount  Int?        // Total reviews at time of snapshot
  newReviews   Int?        // New reviews since previous snapshot
  ratingDelta  Float?      // Rating change since previous snapshot (+0.1, -0.2, etc.)
  source       String      @default("manual") // manual | google_places | scrape

  createdAt    DateTime    @default(now())

  @@unique([locationId, weekStart])
  @@map("gmb_rating_snapshots")
}

// ── ORM-03: Employee Review Platforms ─────────────────────────────────────

model EmployeeReviewPlatform {
  id        String   @id @default(cuid())
  platform  String   // GLASSDOOR | AMBITION_BOX | INDEED | LINKEDIN
  business  String   // Square Yards, Interior Company, etc.
  url       String
  isActive  Boolean  @default(true)

  snapshots EmployeeReviewSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employee_review_platforms")
}

model EmployeeReviewSnapshot {
  id          String                 @id @default(cuid())
  platformId  String
  platform    EmployeeReviewPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  weekStart    DateTime
  rating       Float?
  reviewCount  Int?
  newReviews   Int?
  ratingDelta  Float?
  source       String   @default("manual")

  createdAt   DateTime @default(now())

  @@unique([platformId, weekStart])
  @@map("employee_review_snapshots")
}

// ── YouTube Integration ────────────────────────────────────────────────────

model YoutubeIntegration {
  id              String    @id @default(cuid())
  userId          String
  channelId       String                        // YouTube channel ID (UCxxx...)
  channelName     String?
  channelHandle   String?                       // @handle (without @)
  thumbnailUrl    String?
  subscriberCount Int?
  videoCount      Int?
  viewCount       BigInt?
  accessToken     String    @db.Text
  refreshToken    String?   @db.Text
  tokenExpiresAt  DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])

  @@unique([userId, channelId])
  @@map("youtube_integrations")
}

// ── LinkedIn Integration ───────────────────────────────────────────────────

model LinkedinIntegration {
  id              String    @id @default(cuid())
  userId          String
  organizationId  String                        // URN e.g. "urn:li:organization:12345"
  name            String?
  vanityName      String?                       // company URL slug
  logoUrl         String?
  followerCount   Int?
  accessToken     String    @db.Text
  refreshToken    String?   @db.Text
  tokenExpiresAt  DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId])
  @@map("linkedin_integrations")
}

// ── DesignOps — Design Request Tracker ────────────────────────────────────

enum DesignRequestType {
  VIDEO_EDIT          // Edit existing raw footage
  VIDEO_SHOOT         // Full production shoot + edit
  GRAPHIC_SOCIAL      // Social media graphics (posts, stories, covers)
  GRAPHIC_CAMPAIGN    // Paid campaign / ad / email graphics
  OTHER
}

enum DesignRequestStatus {
  NEW          // Submitted, awaiting assignment
  ASSIGNED     // Assigned to a designer, not yet started
  IN_PROGRESS  // Designer actively working
  REVIEW       // Submitted for review by requester/lead
  DELIVERED    // Approved and delivered ✅
  CANCELLED
}

enum RequestingTeam {
  SOCIAL
  PAID_CAMPAIGN
  MARKETING
  HR
  OTHER
  // New teams
  MANAGEMENT
  ADMIN_TEAM
  BUSINESS_UM
  BUSINESS_AZURO
  BUSINESS_PROPVR
  BUSINESS_IPM
  BUSINESS_NRI
  BUSINESS_INDIA_SALES
  PERFORMANCE_MARKETING
  TECH
  CONTENT
  SEO
}

model DesignRequest {
  id              String               @id @default(cuid())
  refId           String               @unique // human-readable e.g. REQ-001
  title           String
  brief           String               @db.Text
  type            DesignRequestType
  requestingTeam  RequestingTeam
  requesterName   String?              // Free-text name of person requesting
  subTeam         String?              // e.g. "UM", "Azuro" for BUSINESS group
  priority        TaskPriority         @default(MEDIUM)
  status          DesignRequestStatus  @default(NEW)
  dueDate         DateTime?
  referenceLinks  String?              @db.Text // comma-separated URLs

  // People
  requestedById   String?              // User who submitted (if logged in)
  assignedToId    String?              // Designer assigned

  // TAT timestamps
  submittedAt     DateTime             @default(now())
  assignedAt      DateTime?
  startedAt       DateTime?
  reviewAt        DateTime?
  deliveredAt     DateTime?

  // TAT in hours (computed on delivery)
  tatHours        Float?

  // Revision tracking
  revisionCount   Int                  @default(0)
  revisionNote    String?              @db.Text

  // Relations
  requestedBy     User?                @relation("RequestedByUser", fields: [requestedById], references: [id])
  assignedTo      User?                @relation("AssignedDesigner", fields: [assignedToId], references: [id])
  notes           DesignRequestNote[]

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@map("design_requests")
}

model DesignRequestNote {
  id        String        @id @default(cuid())
  requestId String
  authorId  String?
  body      String        @db.Text
  isSystem  Boolean       @default(false) // true = auto-generated status-change log
  createdAt DateTime      @default(now())

  request   DesignRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("design_request_notes")
}

// ── DesignOps — Daily Work Log ─────────────────────────────────────────────
// Each designer logs what they completed each day.

model DesignDailyLog {
  id         String   @id @default(cuid())
  userId     String
  logDate    DateTime @db.Date            // date of the log entry (YYYY-MM-DD)
  summary    String   @db.Text            // free-text "what I did today"
  hoursWorked Float?                      // optional hours

  // Optional links to specific requests completed
  requestIds String[] // cuid list of DesignRequest ids referenced

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, logDate])
  @@map("design_daily_logs")
}

// ── SM-05: Publish Notifications ──────────────────────────────────────────

model PublishNotification {
  id             String    @id @default(cuid())
  calendarItemId String
  sentAt         DateTime  @default(now())
  channels       String[]  // SLACK, WHATSAPP, EMAIL, IN_APP
  message        String    @db.Text
  success        Boolean   @default(true)
  error          String?

  calendarItem   ContentCalendarItem @relation(fields: [calendarItemId], references: [id])

  @@map("publish_notifications")
}
