# ── Database (Supabase) ────────────────────────────────────
# Pooled connection — Transaction mode (port 6543)
# Found in Supabase → Project Settings → Database → Connection string → URI (Mode: Transaction)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection — used by Prisma Migrate (port 5432)
# Found in Supabase → Project Settings → Database → Connection string → URI (Mode: Session)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ── NextAuth ──────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ── Social Media APIs ─────────────────────────────────────
META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""

LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

YOUTUBE_API_KEY=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""

TWITTER_API_KEY=""
TWITTER_API_SECRET=""
TWITTER_ACCESS_TOKEN=""
TWITTER_ACCESS_SECRET=""

# ── AI (OpenAI or Anthropic) ──────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ── Notifications ─────────────────────────────────────────
SLACK_BOT_TOKEN=""

# GMB report is generated client-side in the dashboard with a "copy to clipboard" button
# No external messaging service needed

# Cron auth
CRON_SECRET="squarelabs-cron"
